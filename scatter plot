        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# 1. Generate clean, predictable sample data\n",
        "# Seed ensures the random data looks exactly the same every time you run it\n",
        "np.random.seed(42)\n",
        "x = np.random.rand(50) * 100\n",
        "y = x * 1.5 + np.random.randn(50) * 15\n",
        "\n",
        "# 2. Initialize the plot figure size (width, height in inches)\n",
        "plt.figure(figsize=(8, 6))\n",
        "\n",
        "# 3. Create the scatter plot\n",
        "# s=50 sets point size, alpha=0.7 makes points slightly translucent to see overlaps\n",
        "plt.scatter(x, y, color='#3498db', alpha=0.7, edgecolors='black', s=50, label='Data Points')\n",
        "\n",
        "# 4. Add clear labels and title\n",
        "plt.title('Relationship Between X and Y Variables', fontsize=14, fontweight='bold', pad=15)\n",
        "plt.xlabel('Independent Variable (X)', fontsize=12, labelpad=10)\n",
        "plt.ylabel('Dependent Variable (Y)', fontsize=12, labelpad=10)\n",
        "\n",
        "# 5. Add visual aids (Grid and Legend)\n",
        "plt.grid(True, linestyle='--', alpha=0.5)\n",
        "plt.legend(loc='upper left')\n",
        "\n",
        "# 6. Save the plot to your local directory and display it\n",
        "plt.savefig('scatter_plot.png', dpi=300, bbox_inches='tight')\n",
        "plt.show()"
      ]
